rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: podcasts
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The UID of the user who created the podcast.
    //   - title: string (required, < 200 chars) - The title of the podcast.
    //   - description: string (optional, < 2000 chars) - The summary of the podcast.
    //   - audioUrl: string (required, valid URL) - The URL to the audio file.
    //   - pdfUrl: string (optional, valid URL) - The URL to the source PDF.
    //   - script: string (optional, < 100000 chars) - JSON stringified script.
    //   - chapters: string (optional, < 10000 chars) - JSON stringified chapters.
    //   - showNotes: string (optional, < 10000 chars) - The show notes.
    //   - language: string (optional, < 50 chars) - The language of the podcast.
    //   - duration: number (optional, >= 0) - The duration of the podcast in seconds.
    //   - createdAt: timestamp (required) - The date the podcast was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function isValidUrl(url) {
       return url is string &&
         (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidOptionalUrl(field) {
       return !(field in request.resource.data) || request.resource.data[field] == null || isValidUrl(request.resource.data[field]);
    }

    function isValidOptionalString(field, maxLen) {
       return !(field in request.resource.data) || request.resource.data[field] == null || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }

    function isValidOptionalNumber(field) {
       return !(field in request.resource.data) || request.resource.data[field] == null || (request.resource.data[field] is number && request.resource.data[field] >= 0);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidPodcast(data) {
      return hasRequiredFields(['uid', 'title', 'audioUrl', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'title', 'description', 'audioUrl', 'pdfUrl', 'script', 'chapters', 'showNotes', 'language', 'duration', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.audioUrl is string && isValidUrl(data.audioUrl) &&
             isValidOptionalString('description', 2000) &&
             isValidOptionalUrl('pdfUrl') &&
             isValidOptionalString('script', 100000) &&
             isValidOptionalString('chapters', 10000) &&
             isValidOptionalString('showNotes', 10000) &&
             isValidOptionalString('language', 50) &&
             isValidOptionalNumber('duration') &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /podcasts/{podcastId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidPodcast(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidPodcast(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }
  }
}
