rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Schema Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.createdAt is timestamp;
    }

    function isValidPublisher(data) {
      return data.keys().hasAll(['id', 'name', 'ownerId', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    function isValidIssue(data) {
      return data.keys().hasAll(['id', 'publisherId', 'title', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.publisherId is string
        && data.title is string && data.title.size() <= 300
        && data.status in ['draft', 'published']
        && data.createdAt is timestamp;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // No blanket listing of users to protect PII
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().keys().size() >= 3;
        
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'subscriptions', 'listeningHistory'])
        && ( !('subscriptions' in incoming()) || (incoming().subscriptions is list && incoming().subscriptions.size() <= 1000) )
        && ( !('listeningHistory' in incoming()) || (incoming().listeningHistory is list && incoming().listeningHistory.size() <= 500) );
    }

    // PUBLISHERS COLLECTION
    match /publishers/{publisherId} {
      allow get: if true; // Public access to publisher profiles
      allow list: if true; // Allows discovery
      
      allow create: if isSignedIn()
        && isValidId(publisherId)
        && isValidPublisher(incoming())
        && incoming().id == publisherId;
        
      allow update: if isSignedIn()
        && existing().ownerId == request.auth.uid // Master Gate: Must be owner
        && incoming().ownerId == existing().ownerId // Immortal Field
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'bio', 'logoUrl', 'websiteUrl']);
        
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      // ISSUES SUBCOLLECTION
      match /issues/{issueId} {
        
        allow get: if isValidId(publisherId) && isValidId(issueId) && (existing().status == 'published' || (isSignedIn() && get(/databases/$(database)/documents/publishers/$(publisherId)).data.ownerId == request.auth.uid));
        
        allow list: if existing().status == 'published' || (isSignedIn() && get(/databases/$(database)/documents/publishers/$(publisherId)).data.ownerId == request.auth.uid);
        
        allow create: if isSignedIn()
          && isValidId(publisherId)
          && isValidId(issueId)
          && get(/databases/$(database)/documents/publishers/$(publisherId)).data.ownerId == request.auth.uid // Identity enforcement
          && isValidIssue(incoming())
          && incoming().publisherId == publisherId
          && incoming().id == issueId;
          
        allow update: if isSignedIn()
          && isValidId(publisherId)
          && isValidId(issueId)
          && get(/databases/$(database)/documents/publishers/$(publisherId)).data.ownerId == request.auth.uid
          && incoming().publisherId == existing().publisherId // Immortal Field
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'coverUrl', 'extractedText', 'aiScript', 'audioUrl', 'status']);
          
        allow delete: if isSignedIn() 
          && isValidId(publisherId)
          && isValidId(issueId)
          && get(/databases/$(database)/documents/publishers/$(publisherId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
