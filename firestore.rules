rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: podcasts
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The UID of the user who created the podcast.
    //   - title: string (required, < 200 chars) - The title of the podcast.
    //   - audioUrl: string (required, valid URL) - The URL to the audio file.
    //   - createdAt: timestamp (required) - The date the podcast was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function isValidUrl(url) {
       return url is string &&
         (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidPodcast(data) {
      return hasRequiredFields(['uid', 'title', 'audioUrl', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'title', 'audioUrl', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.audioUrl is string && isValidUrl(data.audioUrl) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /podcasts/{podcastId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidPodcast(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidPodcast(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }
  }
}
