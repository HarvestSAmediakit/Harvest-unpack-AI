{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile with subscriptions and listening history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "subscriptions": { "type": "array", "items": { "type": "string" } },
        "listeningHistory": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "publishers": {
      "title": "Publisher",
      "description": "Publisher channel metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "logoUrl": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "issues": {
      "title": "Issue",
      "description": "Magazine issue with extracted text and AI scripts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "publisherId": { "type": "string" },
        "title": { "type": "string" },
        "coverUrl": { "type": "string" },
        "extractedText": { "type": "string" },
        "aiScript": { "type": "array", "items": { "type": "object", "properties": { "speaker": { "type": "string" }, "text": { "type": "string" } } } },
        "audioUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "publisherId", "title", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Users tracking subscriptions and history."
    },
    "/publishers/{publisherId}": {
      "schema": "publishers",
      "description": "Channel metadata for publishers."
    },
    "/publishers/{publisherId}/issues/{issueId}": {
      "schema": "issues",
      "description": "Subcollection of issues owned by a publisher."
    }
  }
}
